      "id": 1,
      "title": "AD CPU Usage %",
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 - (avg by(instance) (rate(windows_cpu_time_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 0},
      "id": 2,
      "title": "AD Memory Usage %",
      "type": "timeseries",
      "targets": [
        {
          "expr": "(1 - (windows_memory_available_bytes / windows_memory_total_bytes)) * 100",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {"defaults": {}, "overrides": []},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 0},
      "id": 3,
      "title": "AD Disk Usage %",
      "type": "timeseries",
      "targets": [
        {
          "expr": "100 * (windows_logical_disk_size_bytes - windows_logical_disk_free_bytes) / windows_logical_disk_size_bytes",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
    },
