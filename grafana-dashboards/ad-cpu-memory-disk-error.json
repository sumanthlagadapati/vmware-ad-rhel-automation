      "title": "AD Error Percentage (example)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(windows_service_status{status=\"error\"}[5m])) by (instance)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ]
