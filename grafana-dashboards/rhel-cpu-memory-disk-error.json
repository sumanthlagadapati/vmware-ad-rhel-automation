            "id": 3,
            "title": "RHEL Disk Usage %",
            "type": "timeseries",
            "targets": [
                {
                    "expr": "100 * (node_filesystem_size_bytes{mountpoint=\"/\"} - node_filesystem_free_bytes{mountpoint=\"/\"}) / node_filesystem_size_bytes{mountpoint=\"/\"}",
